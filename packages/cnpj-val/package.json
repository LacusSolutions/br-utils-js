{
  "name": "@lacussoft/cnpj-val",
  "version": "2.0.2",
  "description": "Utility to validate CNPJ (Brazilian Business Tax ID)",
  "license": "MIT",
  "author": {
    "name": "Julio L. Muller",
    "url": "https://github.com/juliolmuller"
  },
  "keywords": [
    "cnpj",
    "valid",
    "validate",
    "validator",
    "validador",
    "validar",
    "pt-br",
    "br"
  ],
  "homepage": "https://cnpj-utils.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LacusSolutions/br-utils-js.git"
  },
  "bugs": {
    "url": "https://github.com/LacusSolutions/br-utils-js/issues"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "README.pt.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rollup --config",
    "type-check": "tsc --noEmit",
    "lint": "bun run lint:ci --fix",
    "lint:ci": "eslint src/ tests/ rollup.config.mjs",
    "test": "bun run test:ci --coverage --coverage-reporter=lcov --coverage-dir=tests/__coverage__",
    "test:ci": "bun test --only-failures"
  },
  "dependencies": {
    "@lacussoft/cnpj-dv": "workspace:*",
    "@lacussoft/utils": "workspace:*"
  }
}
